############################################
# TEXT NORMALIZATION
############################################

# Auto-detect text files, normalize to LF in repo
* text=auto eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Shell scripts
*.sh text eol=lf

############################################
# UNITY - SMARTER MERGE (YAML)
############################################

# Unity scene/prefab/asset files are YAML; Unity provides a YAML merge tool (UnityYAMLMerge)
# NOTE: This only helps if devs configure git to use UnityYAMLMerge as "unityyamlmerge" driver.
*.unity  text merge=unityyamlmerge eol=lf
*.prefab text merge=unityyamlmerge eol=lf
*.asset  text merge=unityyamlmerge eol=lf
*.mat    text merge=unityyamlmerge eol=lf
*.controller text merge=unityyamlmerge eol=lf
*.anim   text merge=unityyamlmerge eol=lf
*.overrideController text merge=unityyamlmerge eol=lf
*.playable text merge=unityyamlmerge eol=lf
*.physicMaterial text merge=unityyamlmerge eol=lf
*.physicsMaterial2D text merge=unityyamlmerge eol=lf
*.renderTexture text merge=unityyamlmerge eol=lf

# Meta files should be treated as text (keep LF)
*.meta text eol=lf

